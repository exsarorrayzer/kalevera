<UserControl x:Class="Kalevera.Views.SettingsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Kalevera.ViewModels"
             Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVis}}"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <!-- Overlay -->
    <Border Background="#CC000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <!-- Dialog -->
        <Border Background="{DynamicResource SecondaryBgBrush}"
                CornerRadius="8"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Width="560" MaxHeight="520"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="20,16" Background="{DynamicResource TertiaryBgBrush}"
                        CornerRadius="8,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/icon-settings.png" Width="18" Height="18"
                                   Margin="0,0,10,0" VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock Text="Settings" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="&#x00D7;"
                                Style="{DynamicResource FlatButton}"
                                Command="{Binding CloseCommand}"
                                FontSize="18" Padding="8,4"
                                Foreground="{DynamicResource SecondaryTextBrush}" />
                    </Grid>
                </Border>

                <!-- Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <StackPanel>

                        <!-- Theme Section -->
                        <TextBlock Text="THEME" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,10" />

                        <Border Background="{DynamicResource TertiaryBgBrush}" CornerRadius="6" Padding="2"
                                Margin="0,0,0,20">
                            <ItemsControl ItemsSource="{Binding Themes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ThemeOption}">
                                        <RadioButton Margin="0,1"
                                                     Command="{Binding DataContext.SelectThemeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     CommandParameter="{Binding}"
                                                     GroupName="ThemeGroup"
                                                     FontSize="13"
                                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                                     Padding="12,9"
                                                     Cursor="Hand">
                                            <RadioButton.Template>
                                                <ControlTemplate TargetType="RadioButton">
                                                    <Border x:Name="border"
                                                            Background="Transparent"
                                                            CornerRadius="5"
                                                            Padding="0">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Color preview dot -->
                                                                <Border Width="14" Height="14"
                                                                        CornerRadius="7"
                                                                        Background="{Binding AccentColor}"
                                                                        BorderThickness="0"
                                                                        VerticalAlignment="Center"
                                                                        Margin="0,0,10,0" />

                                                                <TextBlock Text="{Binding Name}"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="13"
                                                                           Foreground="{DynamicResource PrimaryTextBrush}" />

                                                                <!-- Checkmark -->
                                                                <TextBlock Grid.Column="2"
                                                                           Text="&#x2713;"
                                                                           FontSize="12"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource AccentRedBrush}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="8,0,8,0">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBgBrush}" />
                                                            </Trigger>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentRedSubtleBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                            </RadioButton.Template>
                                        </RadioButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Credits Section -->
                        <TextBlock Text="CREDITS" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,10" />

                        <Border Background="{DynamicResource TertiaryBgBrush}" CornerRadius="6" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Kalevera" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentRedBrush}" />
                                <TextBlock Text="v1.0" FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,2,0,12" />

                                <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,12" />

                                <TextBlock Text="Made By" FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,0,0,4" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Rayzer" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Cursor="Hand"
                                            MouseLeftButtonDown="GitHubLink_Click">
                                    <Image Source="/Assets/icon-github.png" Width="22" Height="22"
                                           Margin="0,0,8,0" VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <TextBlock Text="exsarorrayzer" FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}">
                                    <Run Text="Contact: " />
                                    <Run Text="theleapy@proton.me" Foreground="{DynamicResource PrimaryTextBrush}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Border>
</UserControl>
