<Window x:Class="Kalevera.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Kalevera.ViewModels"
        xmlns:views="clr-namespace:Kalevera.Views"
        xmlns:converters="clr-namespace:Kalevera.Converters"
        Title="Kalevera"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/kalevra.png"
        ResizeMode="CanResizeWithGrip"
        x:Name="MainWindowRoot"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
    </Window.Resources>

    <Border Background="{DynamicResource PrimaryBgBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource SecondaryBgBrush}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0">
                        <Image Source="/kalevra.png" Width="18" Height="18" Margin="0,0,8,0"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Kalevera" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{DynamicResource AccentRedBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Style="{DynamicResource FlatButton}"
                                Click="ImportFetch_Click"
                                Padding="10,4"
                                FontSize="11.5"
                                ToolTip="Import a fetch() command from browser DevTools">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Import Fetch" FontSize="11.5" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Style="{DynamicResource FlatButton}"
                                Click="SaveRequest_Click"
                                Padding="10,4"
                                FontSize="11.5"
                                ToolTip="Save current request to selected collection">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Save" FontSize="11.5" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{DynamicResource FlatButton}"
                                Click="Settings_Click"
                                Width="36" Height="36" FontSize="14"
                                FontFamily="Segoe MDL2 Assets"
                                ToolTip="Settings"
                                Foreground="{DynamicResource SecondaryTextBrush}">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" />
                        </Button>
                        <Button Style="{DynamicResource FlatButton}" Click="Minimize_Click"
                                Width="46" Height="36" ToolTip="Minimize">
                            <Path Data="M 0,5.5 L 11,5.5"
                                  Stroke="{DynamicResource SecondaryTextBrush}"
                                  StrokeThickness="1" Stretch="Uniform" Width="11" Height="11" />
                        </Button>
                        <Button Style="{DynamicResource FlatButton}" Click="Maximize_Click"
                                Width="46" Height="36" ToolTip="Maximize">
                            <Path Data="M 1,1 L 10,1 L 10,10 L 1,10 Z"
                                  Stroke="{DynamicResource SecondaryTextBrush}"
                                  StrokeThickness="1" Stretch="Uniform" Width="11" Height="11" />
                        </Button>
                        <Button Style="{DynamicResource FlatButton}" Click="Close_Click"
                                Width="46" Height="36" ToolTip="Close">
                            <Path Data="M 1.5,1.5 L 9.5,9.5 M 9.5,1.5 L 1.5,9.5"
                                  Stroke="{DynamicResource AccentRedBrush}"
                                  StrokeThickness="1.2" Stretch="Uniform" Width="11" Height="11" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" MinWidth="200" MaxWidth="400" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <views:CollectionsSidebar x:Name="Sidebar" Grid.Column="0" />

                <GridSplitter Grid.Column="1" Width="1"
                              Background="{DynamicResource BorderBrush}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext" />

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" MinHeight="100" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="*" MinHeight="150" />
                    </Grid.RowDefinitions>

                    <views:RequestBuilder x:Name="RequestBuilderCtrl" Grid.Row="0"
                                          DataContext="{Binding RequestVM}" />

                    <GridSplitter Grid.Row="1" Height="5"
                                  Background="{DynamicResource BorderBrush}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  ResizeBehavior="PreviousAndNext" />

                    <views:ResponseViewer Grid.Row="2"
                                          DataContext="{Binding ResponseVM}" />
                </Grid>
            </Grid>

            <Border Grid.Row="2" Background="{DynamicResource SecondaryBgBrush}"
                    CornerRadius="0,0,6,6">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Kalevera v1.0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11" VerticalAlignment="Center" />

                    <TextBlock Grid.Column="1" Text=""
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <views:FetchConverterDialog DataContext="{Binding FetchConverterVM}"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                        Grid.RowSpan="3" />

            <views:SettingsDialog DataContext="{Binding SettingsVM}"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  Grid.RowSpan="3" />
        </Grid>
    </Border>
</Window>
