<UserControl x:Class="Kalevera.Views.ResponseViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Kalevera.Views"
             Margin="12,0,12,8">

    <Border Background="{DynamicResource SecondaryBgBrush}"
            CornerRadius="6"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <!-- Loading State -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <ProgressBar Width="200" Height="3" IsIndeterminate="True" Margin="0,0,0,12" />
                <TextBlock Text="Sending request..."
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="13" HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Empty State -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding HasResponse, Converter={StaticResource InvBoolToVis}}">
                <TextBlock Text="No Response" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TertiaryBgBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,6" />
                <TextBlock Text="Send a request to see the response here"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12" HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Response Content -->
            <Grid Visibility="{Binding HasResponse, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Status Bar -->
                <Border Grid.Row="0" Padding="12,8" Background="{DynamicResource TertiaryBgBrush}"
                        CornerRadius="6,6,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Border CornerRadius="4" Padding="8,3"
                                Background="{Binding Response.StatusCode, Converter={StaticResource StatusToColorConverter}}"
                                Margin="0,0,12,0">
                            <TextBlock FontWeight="Bold" FontSize="12" Foreground="White">
                                <Run Text="{Binding Response.StatusCode, Mode=OneWay}" />
                                <Run Text=" " />
                                <Run Text="{Binding Response.StatusText, Mode=OneWay}" />
                            </TextBlock>
                        </Border>

                        <TextBlock VerticalAlignment="Center" FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,16,0">
                            <Run Text="Time: " />
                            <Run Text="{Binding Response.ElapsedMs, Mode=OneWay}" />
                            <Run Text="ms" />
                        </TextBlock>

                        <TextBlock VerticalAlignment="Center" FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}">
                            <Run Text="Size: " />
                            <Run Text="{Binding Response.ContentLength, Mode=OneWay}" />
                            <Run Text=" bytes" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Tabs: Body, Headers -->
                <TabControl Grid.Row="1" Margin="0">
                    <TabItem Header="Body">
                        <Grid>
                            <!-- Error Display -->
                            <Border Visibility="{Binding Response.Error, Converter={StaticResource StringToVis}}"
                                    Background="#33E63946" CornerRadius="4" Margin="12">
                                <StackPanel Margin="12">
                                    <TextBlock Text="Error" FontWeight="Bold" Foreground="{DynamicResource AccentRedBrush}"
                                               FontSize="13" Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding Response.Error}" TextWrapping="Wrap"
                                               Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" />
                                </StackPanel>
                            </Border>

                            <ScrollViewer Visibility="{Binding Response.Error, Converter={StaticResource InvStringToVis}}"
                                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                <TextBox Text="{Binding Response.Body, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Background="Transparent"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         BorderThickness="0"
                                         Padding="12"
                                         AcceptsReturn="True" />
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Headers">
                        <DataGrid ItemsSource="{Binding Response.Headers}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  Background="{DynamicResource SecondaryBgBrush}"
                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="*" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Border>
</UserControl>
