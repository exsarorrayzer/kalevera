<UserControl x:Class="Kalevera.Views.FetchConverterDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Kalevera.ViewModels"
             Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVis}}"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Border Background="#CC000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border Background="{DynamicResource SecondaryBgBrush}"
                CornerRadius="8"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Width="680" MaxHeight="520"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="20,16" Background="{DynamicResource TertiaryBgBrush}"
                        CornerRadius="8,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Import from Fetch" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="&#x00D7;"
                                Style="{DynamicResource FlatButton}"
                                Command="{Binding CloseCommand}"
                                FontSize="18" Padding="8,4"
                                Foreground="{DynamicResource SecondaryTextBrush}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="20,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox x:Name="FetchInputBox"
                             Grid.Row="0"
                             Text="{Binding FetchInput, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12.5"
                             Padding="12"
                             Background="{DynamicResource PrimaryBgBrush}"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1"
                             VerticalContentAlignment="Top">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Tag" Value="Paste fetch() command here..." />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBlock Grid.Row="0"
                               Text="Paste fetch() command here..."
                               FontFamily="Consolas"
                               FontSize="12.5"
                               Foreground="#555555"
                               Padding="14,14"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=FetchInputBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Border Grid.Row="1"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                            Background="#33E63946"
                            CornerRadius="4"
                            Margin="0,8,0,0"
                            Padding="10,8">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource AccentRedBrush}"
                                   FontSize="12" TextWrapping="Wrap" />
                    </Border>
                </Grid>

                <Border Grid.Row="2" Padding="20,12" Background="{DynamicResource TertiaryBgBrush}"
                        CornerRadius="0,0,8,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                   FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}">
                            Works with: fetch('url', {method, headers, body})
                        </TextBlock>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Cancel"
                                    Style="{DynamicResource FlatButton}"
                                    Command="{Binding CloseCommand}"
                                    Padding="14,7"
                                    Margin="0,0,8,0"
                                    FontSize="12.5" />
                            <Button Content="Import Request"
                                    Command="{Binding ParseCommand}"
                                    Padding="14,7"
                                    FontSize="12.5" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Border>
</UserControl>
